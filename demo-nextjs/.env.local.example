# Blockfrost preprod project id (required). Exposed to the browser because Lucid signs txs client-side.
NEXT_PUBLIC_BLOCKFROST_PROJECT_ID=preprod...

# OpenAI key for the AI agent panel. Server-only.
OPENAI_API_KEY=sk-...

# Demo wallet seed used by /api/refresh and /api/agent to sign Round 2 txs server-side.
# Local dev: leave blank, the routes fall back to ./.wallet.seed written by `npm run setup`.
# Vercel: paste the contents of .wallet.seed here.
DEMO_WALLET_SEED=

# Contract + oracle artifacts. Written by `npm run setup` to ./artifacts.json.
# Local dev: leave blank, the /api/script route reads the file from disk.
# Vercel: paste the full JSON contents of artifacts.json as a single line.
DEMO_ARTIFACTS_JSON=
